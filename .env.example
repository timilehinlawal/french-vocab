# Firebase web app config — copy to ".env.local" and fill in your project's values.
# Find these in Firebase Console → Project settings → "Your apps" → SDK setup.
# These are public identifiers (safe to ship in the frontend), not secrets.
# Leave them blank to run the app in local-only mode (no sign-in, localStorage only).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
